# =========================================================================
# LLM Output Arbitration System — environment configuration
# Copy to `.env` and fill in what you have. Anything left blank falls back
# to the deterministic offline "mock" backend, so the whole system runs
# end-to-end with zero API keys.
# =========================================================================

# ---- Provider routing -------------------------------------------------
# Each critic can be routed to a different backend. Valid backends:
#   openai | anthropic | ollama | mock
# The spec routes accuracy->GPT-4o, logic->Claude, completeness->Llama.
ARBITER_ACCURACY_BACKEND=mock
ARBITER_LOGIC_BACKEND=mock
ARBITER_COMPLETENESS_BACKEND=mock
ARBITER_ADJUDICATOR_BACKEND=mock

# Set to "auto" to use the real backend when its key/host is available and
# transparently fall back to mock otherwise. Set to "strict" to error if a
# configured real backend is unavailable.
ARBITER_BACKEND_MODE=auto

# ---- Model names per provider ----------------------------------------
ARBITER_OPENAI_MODEL=gpt-4o
ARBITER_ANTHROPIC_MODEL=claude-sonnet-5
ARBITER_OLLAMA_MODEL=llama3.1

# ---- Credentials / hosts ---------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ---- Reliability ------------------------------------------------------
ARBITER_MAX_RETRIES=2
ARBITER_RETRY_BACKOFF=1.5

# ---- Storage ----------------------------------------------------------
ARBITER_DB_PATH=data/arbitrations.sqlite
ARBITER_JSON_DIR=data/arbitrations
